# ─── dependencies ─────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── testing ──────────────────────────────────────────────────────────────────
/coverage

# ─── next.js ──────────────────────────────────────────────────────────────────
/.next/
/out/

# ─── production ───────────────────────────────────────────────────────────────
/build

# ─── misc ─────────────────────────────────────────────────────────────────────
.DS_Store
*.pem
Thumbs.db

# ─── debug ────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── env files ────────────────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.example is intentionally NOT ignored

# ─── database (runtime data — use Railway volume for persistence) ─────────────
/data/
*.sqlite
*.sqlite-shm
*.sqlite-wal

# ─── uploads (runtime) ────────────────────────────────────────────────────────
/public/uploads/
/uploads/

# ─── logs (runtime) ───────────────────────────────────────────────────────────
/logs/
*.log

# ─── vercel ───────────────────────────────────────────────────────────────────
.vercel

# ─── typescript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── ai / editor tool caches ──────────────────────────────────────────────────
.gemini/
.opencode/
