# TestMarks Environment Configuration
# Copy this to .env and fill in values

# Database (SQLite path — Railway: use /data/database.sqlite with volume)
DATABASE_URL=./data/database.sqlite

# Admin Credentials (CHANGE THESE!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# Session Secret (generate a random 32+ char string)
SESSION_SECRET=change-this-to-a-random-secret

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@testmarks.com

# Sentry (optional)
SENTRY_DSN=

# Redis (optional — for caching)
REDIS_URL=
REDIS_PASSWORD=

# Application
NODE_ENV=production
NEXT_PUBLIC_APP_NAME=TestMarks
NEXT_PUBLIC_APP_URL=https://your-app.up.railway.app
